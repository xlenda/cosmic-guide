{
  "expo": {
    "name": "Cosmic Oracle é seu guia cósmico pessoal",
    "slug": "cosmic-oracle-seu-guia-c-smico",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wron.app0gg0zwnopp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.wron.app0gg0zwnopp"
    },
    "experiments": {
      "baseUrl": "/cosmic-guide"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permitir acesso à câmera para fotografar sua palma da mão ou a borra do café para a leitura simbólica.",
          "photosPermission": "Permitir acesso às fotos para escolher uma imagem da palma da mão ou da borra do café para a leitura simbólica.",
          "microphonePermission": false
        }
      ]
    ]
  }
}
