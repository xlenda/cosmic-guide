# Meta Pixel — Business Manager > Fontes de dados > Pixels. Sem isso, o app
# não carrega o script do Pixel (nenhum evento é enviado). Mesmo Pixel usado
# no funil web (c:/tmp/gilfforever/web/.env.example), pra medir o mesmo funil
# nos dois lugares.
EXPO_PUBLIC_FB_PIXEL_ID=

# GA4 Measurement ID — Google Analytics > Admin > Fluxos de dados (formato G-XXXXXXX).
EXPO_PUBLIC_GA_ID=
